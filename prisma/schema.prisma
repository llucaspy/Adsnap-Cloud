generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Campaign {
  id              String          @id @default(cuid())
  agency          String
  client          String
  campaignName    String          @default("")
  pi              String
  format          String
  url             String
  device          String          @default("desktop")
  status          String          @default("PENDING")
  segmentation    String          @default("PRIVADO")
  flightStart     DateTime?
  flightEnd       DateTime?
  isArchived      Boolean         @default(false)
  isScheduled     Boolean         @default(false)
  scheduledTimes  String          @default("[]")
  lastCaptureAt   DateTime?
  retryCount      Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  externalAuthUrl     String?
  externalCampaignId  String?
  isMonitoringActive  Boolean         @default(false)
  manualDashboardUrl  String?
  dailyGoalThreshold  Int?
  lastThresholdAlertAt DateTime?
  captures            Capture[]
  emailDispatches EmailDispatch[]
}

model Capture {
  id             String   @id @default(cuid())
  campaignId     String
  screenshotPath String
  status         String   @default("SUCCESS")
  auditNotes     String?
  createdAt      DateTime @default(now())
  campaign       Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model Settings {
  id                    Int       @id @default(1)
  nexusMaxRetries       Int       @default(3)
  nexusTimeout          Int       @default(60000)
  nexusDelay            Int       @default(3000)
  autoCleanupDays       Int       @default(30)
  webhookUrl            String?
  performanceMode       Boolean   @default(false)
  feedPollingRate       Int       @default(5000)
  maintenanceMode       Boolean   @default(false)
  bannerFormats         String    @default("[]")
  updatedAt             DateTime  @updatedAt
  storageCheckFrequency Int       @default(24)
  storageCheckLastRun   DateTime?
  telegramBotToken      String?
  telegramChatId        String?
  telegramAlertsEnabled Boolean   @default(true)
  telegramLastAlertAt   DateTime?
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("user")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NexusLog {
  id         String   @id @default(cuid())
  level      String
  message    String
  details    String?
  campaignId String?
  createdAt  DateTime @default(now())
}

model EmailDispatch {
  id           String    @id @default(cuid())
  campaignId   String?
  recipients   String
  dispatchTime String    @default("09:00")
  isActive     Boolean   @default(true)
  lastSentAt   DateTime?
  status       String    @default("PENDING")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  pi           String    @default("")
  campaign     Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model DailyMetric {
  id           String   @id @default(cuid())
  campaignId   String
  date         DateTime @default(now())
  delivered    Int
  viewability  Float
  goal         Int
  pacing       Float
  createdAt    DateTime @default(now())

  @@unique([campaignId, date])
}
