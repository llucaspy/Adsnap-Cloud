generator client {
  provider = "prisma-client-js"
  output   = "c:/Users/lucas.mendonça/Desktop/Adsnap-Cloud/prisma/sqlite-client"
}

datasource db {
  provider = "sqlite"
  url      = "file:c:/Users/lucas.mendonça/Desktop/Adsnap v2/prisma/dev.db"
}

model Campaign {
  id             String    @id
  agency         String
  client         String
  campaignName   String    @default("")
  pi             String
  format         String
  url            String
  device         String    @default("desktop")
  status         String    @default("PENDING")
  segmentation   String    @default("PRIVADO")
  flightStart    DateTime?
  flightEnd      DateTime?
  isArchived     Boolean   @default(false)
  isScheduled    Boolean   @default(false)
  scheduledTimes String    @default("[]")
  lastCaptureAt  DateTime?
  retryCount     Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime
  Capture        Capture[]
}

model Capture {
  id             String   @id
  campaignId     String
  screenshotPath String
  status         String   @default("SUCCESS")
  createdAt      DateTime @default(now())
  auditNotes     String?
  Campaign       Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model Settings {
  id              Int      @id @default(autoincrement())
  nexusMaxRetries Int      @default(3)
  nexusTimeout    Int      @default(60000)
  nexusDelay      Int      @default(3000)
  autoCleanupDays Int      @default(30)
  webhookUrl      String?
  performanceMode Boolean  @default(false)
  feedPollingRate Int      @default(5000)
  maintenanceMode Boolean  @default(false)
  bannerFormats   String   @default("[]")
  updatedAt       DateTime
}

model User {
  id        String   @id
  email     String   @unique
  password  String
  name      String
  role      String   @default("user")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
}
